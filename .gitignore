# ============================================================================
# Early Dementia Detection - .gitignore
# ============================================================================
# Rules cover: Python, FastAPI, PyTorch, React/Vite, Node, OS junk, secrets.
# `.gitignore` only blocks UNTRACKED files. For files already in git history,
# use `git rm --cached <path>` (commands at the bottom of this file's notes).
# ============================================================================


# ----------------------------------------------------------------------------
# 1. Environment files / secrets  (NEVER commit)
# ----------------------------------------------------------------------------
.env
.env.*
.env.local
.env.*.local
backend/.env
backend/.env.*
frontend/.env
frontend/.env.*
frontend/.env.development
frontend/.env.production
*.pem
*.key
secrets/
.envrc

# ----------------------------------------------------------------------------
# 2. Python
# ----------------------------------------------------------------------------
__pycache__/
**/__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/
.python-version
pip-log.txt
pip-delete-this-directory.txt

