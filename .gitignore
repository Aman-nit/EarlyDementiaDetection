# ============================================================================
# To untrack files that are ALREADY in git history:
# ============================================================================
#   # Remove from index, keep on disk
#   git rm -r --cached .venv
#   git rm -r --cached frontend/node_modules
#   git rm -r --cached "backend/Datasets"
#   git rm -r --cached backend/__pycache__ backend/ml/__pycache__ \
#                     backend/models/__pycache__ backend/routes/__pycache__ \
#                     backend/services/__pycache__
#   git rm --cached "_.svg" 2>/dev/null || true
#   git rm -r --cached backend/uploads
#   git rm --cached dementia_detection.db
#
#   git add .gitignore
#   git commit -m "chore: clean up gitignore and untrack generated artifacts"
# ============================================================================
